# Server
PORT=3001
JWT_SECRET=replace-with-a-strong-secret
DB_PATH=./server/data/app.db

# Optional public compliance footer. Leave ICP_RECORD empty to hide it.
ICP_RECORD=xxx
ICP_RECORD_URL=https://beian.miit.gov.cn/

# Required default login accounts. Put real passwords in .env, never commit them.
DEFAULT_USER1_NAME=xxx1
DEFAULT_USER1_EMAIL=xxx1@xxx.cloud
DEFAULT_USER1_PASSWORD=replace-with-strong-password
DEFAULT_USER2_NAME=xxx2
DEFAULT_USER2_EMAIL=xxx2@xxx.cloud
DEFAULT_USER2_PASSWORD=replace-with-strong-password
DEFAULT_DAILY_GOAL=30

# DeepSeek translation/meaning generation
# Put your real key in .env, never commit it.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

